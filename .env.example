# MongoDB Connection String (MongoDB Atlas recommended)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/metainfosci?retryWrites=true&w=majority

# Resend API Key (Verify domain metainfosci.com in Resend dashboard)
RESEND_API_KEY=re_your_api_key_here

# NextAuth Configuration
# Set NEXTAUTH_SECRET to a random 32-character string (e.g. openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_here
# Set NEXTAUTH_URL to the canonical production URL (e.g. https://your-app.vercel.app)
NEXTAUTH_URL=http://localhost:3000
